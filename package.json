{
  "name": "local-cli",
  "version": "0.0.7",
  "author": "Corey Donenfeld",
  "bin": {
    "local-cli": "./bin/run.js"
  },
  "bugs": "https://github.com/coreydonenfeld/local-cli/issues",
  "dependencies": {
    "@inquirer/confirm": "^6.0.11",
    "@inquirer/input": "^5.0.11",
    "@inquirer/search": "^4.1.7",
    "@inquirer/select": "^5.1.3",
    "@oclif/core": "^4",
    "@oclif/plugin-help": "^6"
  },
  "devDependencies": {
    "@types/node": "^22",
    "oclif": "^4",
    "patch-package": "^8.0.1",
    "ts-node": "^10",
    "typescript": "^5",
    "vitest": "^3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "/bin",
    "/dist",
    "/oclif.manifest.json"
  ],
  "homepage": "https://github.com/coreydonenfeld/local-cli",
  "keywords": [
    "oclif",
    "local",
    "localwp",
    "local by flywheel",
    "graphql",
    "wordpress"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "oclif": {
    "bin": "local-cli",
    "dirname": "local-cli",
    "commands": "./dist/commands",
    "plugins": [
      "@oclif/plugin-help"
    ]
  },
  "repository": "coreydonenfeld/local-cli",
  "scripts": {
    "postinstall": "patch-package",
    "build": "rm -rf dist && tsc -b",
    "postpack": "rm -f oclif.manifest.json",
    "prepack": "npm run build && oclif manifest && oclif readme",
    "test": "vitest run",
    "version": "oclif readme && git add README.md"
  },
  "types": "dist/index.d.ts"
}
